{
  "expo": {
    "name": "CryptoWallet",
    "slug": "CryptoWallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.karthick.cryptowallet",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "CryptoWallet uses the camera to scan QR codes for sending crypto.",
        "NSPhotoLibraryUsageDescription": "CryptoWallet may access your photo library for QR code images.",
        "NSFaceIDUsageDescription": "CryptoWallet uses Face ID to secure your wallet access."
      }
    },
    "android": {
      "package": "com.karthick.cryptowallet",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-system-ui",
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ChainSplit to scan QR codes for sending crypto."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b642bc6a-f2df-412d-839c-7f43ed34fab7"
      }
    }
  }
}
