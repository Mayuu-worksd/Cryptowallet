{
  "info": {
    "_postman_id": "8c35f299-d41f-4ea9-bf88-75c1a84f3319",
    "name": "Codego Sandbox APIs",
    "description": "Official Postman Collection to verify the Codego Sandbox APIs for CryptoWallet integration.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Step 1 – Wallet",
      "item": [
        {
          "name": "Generate/Create Wallet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Wallet has address and privateKey\", function () {",
                  "    pm.expect(jsonData).to.have.property('walletAddress');",
                  "    pm.expect(jsonData).to.have.property('privateKey');",
                  "});",
                  "",
                  "if (jsonData.walletAddress) {",
                  "    pm.environment.set(\"walletAddress\", jsonData.walletAddress);",
                  "    console.log(\"Saved walletAddress:\", jsonData.walletAddress);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chain\": \"base\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/wallets",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "wallets"
              ]
            },
            "description": "Generates a new self-custodial DeFi wallet on the Base chain."
          },
          "response": []
        },
        {
          "name": "Verify wallet creation (Balance)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Balance response structure\", function () {",
                  "    pm.expect(jsonData).to.have.property('balance');",
                  "    pm.expect(jsonData.chain).to.eql('base');",
                  "});"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/wallets/{{walletAddress}}/balance?chain=base",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "wallets",
                "{{walletAddress}}",
                "balance"
              ],
              "query": [
                {
                  "key": "chain",
                  "value": "base"
                }
              ]
            },
            "description": "Fetches the live on-chain USDC balance for the generated wallet address."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Step 2 – Individual KYC",
      "item": [
        {
          "name": "Submit KYC Application (Bypass Key)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"Cardholder created or exists\", function () {",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('applicationStatus');",
                  "});",
                  "",
                  "if (jsonData.id) {",
                  "    pm.environment.set(\"userId\", jsonData.id);",
                  "    console.log(\"Saved userId:\", jsonData.id);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Api-Key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"walletAddress\": \"{{walletAddress}}\",\n  \"email\": \"postman_test_{{$randomInt}}@example.com\",\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Test\",\n  \"birthDate\": \"1990-01-01\",\n  \"phoneNumber\": \"10000000000\",\n  \"phoneCountryCode\": \"1\",\n  \"ipAddress\": \"127.0.0.1\",\n  \"address\": {\n    \"line1\": \"123 Main St\",\n    \"city\": \"Unknown\",\n    \"postalCode\": \"00000\",\n    \"countryCode\": \"US\"\n  },\n  \"nationalId\": \"123456789\",\n  \"countryOfIssue\": \"US\",\n  \"key\": \"{{apiKey}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/applications",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "applications"
              ]
            },
            "description": "Registers a new KYC application in the Codego system using the server-to-server pre-shared bypass 'key' field."
          },
          "response": []
        },
        {
          "name": "Create Sandbox KYC Session",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "pm.test(\"KYC Session response has iframeUrl\", function () {",
                  "    pm.expect(jsonData).to.have.property('iframeUrl');",
                  "    pm.expect(jsonData).to.have.property('sessionId');",
                  "});"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
