            "body": {
              "mode": "raw",
              "raw": "{\n  \"externalUserId\": \"{{userId}}\",\n  \"applicantType\": \"individual\",\n  \"email\": \"postman_test@example.com\",\n  \"returnUrl\": \"https://cryptowallet-dun.vercel.app\"\n}"
            },
            "url": {
              "raw": "https://kyc-sandbox.codegotech.com/api/session/create",
              "protocol": "https",
              "host": [
